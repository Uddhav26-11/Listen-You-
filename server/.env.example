PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/listen-you

# JWT
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d
JWT_COOKIE_NAME=listen_you_token

# AI services — free Groq API key from https://console.groq.com/keys (no billing needed)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
